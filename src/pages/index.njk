---
layout: layouts/base.njk
title: Yannik Glaser, Ph.D.
permalink: /
---

<div class="gol-backdrop">
  <canvas id="gol-canvas" class="gol-backdrop__canvas" aria-hidden="true"></canvas>

  {% include "partials/hero.njk" %}

  <section class="container section about-brief fade-in" style="--fade-order:0">
    <h2 class="about-brief__heading">About</h2>
    <p class="about-brief__text">
      Postdoctoral Researcher at the Research Corporation of Hawaii.
      I build self-supervised learning foundation models for satellite remote sensing,
      medical imaging, and solar physics. Ph.D. in Computer Science from the
      University of Hawaii at Manoa (2025), advised by Peter Sadowski.
    </p>
    <a href="/about/" class="inline-link">More about me &rarr;</a>
  </section>

  <section class="container section fade-in" style="--fade-order:1">
    <div class="exp-slider-header">
      <h2 class="exp-slider-header__title">Experience</h2>
      <a href="/experience/" class="inline-link">View all &rarr;</a>
    </div>

    <ul class="exp-slider">
      {% for entry in collections.experience %}
      <li class="exp-slide">
        <a href="{{ entry.url }}">
          <span class="exp-slide__date">{{ entry.data.dateRange }}</span>
          <span class="exp-slide__title">{{ entry.data.jobTitle }}</span>
          <span class="exp-slide__company">{{ entry.data.company }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>

  <section class="container section fade-in" style="--fade-order:2">
    <div class="exp-slider-header">
      <h2 class="exp-slider-header__title">Education</h2>
      <a href="/about/" class="inline-link">More on About &rarr;</a>
    </div>

    <ul class="exp-slider">
      {% for entry in education %}
      <li class="exp-slide">
        <a href="/about/">
          <span class="exp-slide__date">{{ entry.year }}</span>
          <span class="exp-slide__title">{{ entry.degree }}</span>
          <span class="exp-slide__company">{{ entry.institution }}</span>
        </a>
      </li>
      {% endfor %}
    </ul>
  </section>
</div>

<script src="/assets/js/game-of-life.js"></script>
<script>
(function () {
  var els = document.querySelectorAll(".fade-in");
  if (!els.length || !("IntersectionObserver" in window)) {
    els.forEach(function (el) { el.classList.add("fade-in--visible"); });
    return;
  }
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add("fade-in--visible");
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  els.forEach(function (el) { observer.observe(el); });
})();
</script>
