---
layout: layouts/base.njk
---

<div class="container">
  {% if title %}
  <header class="page-header">
    <h1 class="page-header__title">{{ title }}</h1>
    {% if description %}
    <p class="page-header__description">{{ description }}</p>
    {% endif %}
  </header>
  {% endif %}

  <div class="section">
    {{ content | safe }}
  </div>
</div>
