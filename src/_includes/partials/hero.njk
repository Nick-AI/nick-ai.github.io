<section class="hero">
  <div class="container hero__content">
    <p class="hero__greeting">Hi, I'm</p>
    <h1 class="hero__name">{{ site.shortTitle }}</h1>
    <p class="hero__tagline">{{ site.bio }}</p>

    <a href="/about/#skills" class="skills-typewriter">
      I work with <span class="skills-typewriter__word" id="skill-cycle"></span><span class="skills-typewriter__cursor">|</span>
    </a>
    <script>
      (function() {
        var base = [{% for group in skills %}{% if group.category != "Languages" %}{% for skill in group.items.split(", ") %}"{{ skill }}",{% endfor %}{% endif %}{% endfor %}];
        function shuffle(arr) {
          for (var k = arr.length - 1; k > 0; k--) {
            var r = Math.floor(Math.random() * (k + 1));
            var tmp = arr[k]; arr[k] = arr[r]; arr[r] = tmp;
          }
          return arr;
        }
        var skills = shuffle(base.slice()), i = 0, j = 0, deleting = false, pause = 0;
        var el = document.getElementById("skill-cycle");
        function tick() {
          var word = skills[i];
          if (pause > 0) { pause--; requestAnimationFrame(tick); return; }
          if (!deleting) {
            el.textContent = word.slice(0, ++j);
            if (j === word.length) { deleting = true; pause = 40; }
          } else {
            el.textContent = word.slice(0, --j);
            if (j === 0) {
              deleting = false; pause = 8;
              i++;
              if (i >= skills.length) { skills = shuffle(base.slice()); i = 0; }
            }
          }
          setTimeout(tick, deleting ? 30 : 60);
        }
        tick();
      })();
    </script>

    <div class="hero__links">
      <a href="/about/" class="btn btn--primary">About Me</a>
      <a href="/assets/cv.pdf" class="btn btn--outline" target="_blank" rel="noopener">Resume</a>
